ANTHROPIC_API_KEY=your_key_here

# Supabase (saved profiles, email subscriptions)
# Vercel/Supabase integration provides these automatically
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Database URL (for creating tables - Vercel provides POSTGRES_URL when Supabase is linked)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Cron protection (Vercel cron invokes with this in Authorization header)
CRON_SECRET=

# Admin test mode (for ?admin=true - send test email without waiting)
# Set both to same value so client can call send-test-email API
ADMIN_SECRET=
VITE_ADMIN_SECRET=

# Upstash Redis (optional - for rate limiting save/subscribe)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL (used in emails and share links)
# Use either: NEXT_PUBLIC_APP_URL or VITE_APP_URL
# Example: https://www.mybuddhafamily.org
NEXT_PUBLIC_APP_URL=
VITE_APP_URL=
