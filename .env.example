ANTHROPIC_API_KEY=your_key_here

# Supabase (saved profiles, email subscriptions)
# Use either: NEXT_PUBLIC_SUPABASE_URL or SUPABASE_URL (project URL from Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase database URL (for creating tables - get from Dashboard -> Project Settings -> Database -> Connection string URI)
SUPABASE_DB_URL=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Cron protection (Vercel cron invokes with this in Authorization header)
CRON_SECRET=

# Upstash Redis (optional - for rate limiting save/subscribe)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL (used in emails and share links)
# Use either: NEXT_PUBLIC_APP_URL or VITE_APP_URL
# Example: https://www.mybuddhafamily.org
NEXT_PUBLIC_APP_URL=
VITE_APP_URL=
