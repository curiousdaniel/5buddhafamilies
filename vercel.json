{
  "rewrites": [
    {
      "source": "/((?!api/)(?!assets/)(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/interpret.js": {
      "maxDuration": 60
    },
    "api/profile/regenerate-interpretation.js": {
      "maxDuration": 60
    },
    "api/cron/send-contemplations.js": {
      "maxDuration": 300
    },
    "api/setup/schema.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/send-contemplations",
      "schedule": "0 7 * * *"
    }
  ]
}
